# =====================================================
# .gitignore — Contract Testing Automation Project
# =====================================================
# This file tells Git which files/folders to IGNORE
# (not track). These are files generated by builds,
# IDEs, or OS-specific files that shouldn't be in
# version control.
# =====================================================

# ----- Java / Maven -----
target/                   # Maven build output directory
*.class                   # Compiled Java bytecode files
*.jar                     # Java archive files
*.war                     # Web application archive files
*.ear                     # Enterprise archive files
*.log                     # Log files generated at runtime

# ----- Maven Wrapper (if used) -----
.mvn/wrapper/maven-wrapper.jar

# ----- IDE: IntelliJ IDEA -----
.idea/                    # IntelliJ project settings
*.iml                     # IntelliJ module files
*.iws                     # IntelliJ workspace files
*.ipr                     # IntelliJ project files
out/                      # IntelliJ output directory

# ----- IDE: Eclipse -----
.classpath
.project
.settings/
bin/

# ----- IDE: VS Code -----
# We intentionally KEEP .vscode/ because we store
# launch.json and tasks.json for debugging setup
# .vscode/

# ----- Python -----
__pycache__/              # Python bytecode cache
*.py[cod]                 # Compiled Python files
*.pyo                     # Optimized Python files
.venv/                    # Python virtual environment
venv/                     # Alternative venv directory
env/                      # Alternative env directory
*.egg-info/               # Python package metadata
dist/                     # Python distribution files
build/                    # Python build output

# ----- Environment & Secrets -----
.env                      # Environment variables (may contain secrets!)
.env.local                # Local environment overrides
*.pem                     # SSL/TLS certificates
*.key                     # Private keys

# ----- Operating System -----
.DS_Store                 # macOS folder metadata
Thumbs.db                 # Windows thumbnail cache
Desktop.ini               # Windows folder settings
*.swp                     # Vim swap files
*~                        # Backup files

# ----- Project-specific -----
DEMO_SCRIPT.txt           # Personal demo script (not for repo)
